# --- DBOS ---
# DBOS stores workflow/queue state here.
# Local dev: SQLite file (no Postgres install). Production: use Postgres.
DBOS_SYSTEM_DATABASE_URL=sqlite:///./workflow-explorer.sqlite
# DBOS_SYSTEM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow_explorer
DBOS_APP_NAME=workflow-explorer

# Concurrency for the durable "jobs" queue (consumers running at once).
JOBS_QUEUE_CONCURRENCY=1

# --- LLM (Pydantic AI) ---
# Model id format is ``provider:model`` (colon separator). Examples:
#   anthropic:claude-sonnet-5
#   openai:gpt-5.6-terra
#   openrouter:openai/gpt-5.6-terra   # OpenRouter-hosted models use a slash after the provider
LLM_MODEL=anthropic:claude-sonnet-5
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx            # direct OpenAI (openai:* models)
# OPENROUTER_API_KEY=sk-or-v1-xxxxx  # OpenRouter (openrouter:* models)

# --- Observability (Pydantic Logfire) ---
# Leave blank to disable sending spans (still runs locally).
LOGFIRE_TOKEN=

# --- Webhooks ---
# Bearer token required on webhook requests: `Authorization: Bearer <token>`.
WEBHOOK_BEARER_TOKEN=change-me

# --- Paperless-ngx job ---
# PAPERLESS_URL must point at the Paperless /api root, e.g. http://localhost:8000/api
PAPERLESS_URL=http://localhost:8000/api
PAPERLESS_TOKEN=xxxxx
# Cron for the catch-up sweep (DBOS schedule, UTC).
PAPERLESS_SCAN_CRON=*/30 * * * *
# Max documents to enqueue per sweep/backfill run.
PAPERLESS_SCAN_LIMIT=25
